# Default values (can be overridden by account blocks)
defaults
auth           on
tls            on
tls_certcheck  on
tls_trust_file system
logfile        ~/.msmtp.log

# Account UPM
account      upm
host         smtp.upm.es
port         587
from         marco.perez@alumnos.upm.es
user         marco.perez@alumnos.upm.es
auth         on
tls          on
tls_starttls on
passwordeval gpg --no-tty -qd ~/.authinfo.gpg | awk '/machine correo.alumnos.upm.es/ {print $6; exit}' | tr -d '\"'

# Account IMDEA
account      imdea
host         mail.imdea.org
port         587
from         marco.perez@imdea.org
user         marco.perez@imdea.org
auth         on
tls          on
tls_starttls on
passwordeval gpg --no-tty -qd ~/.authinfo.gpg | awk '/machine mail.imdea.org/ {print $6; exit}' | tr -d '\"'
# Account UDC
# account udc
# auth xoauth2
# tls on
# host smtp.office365.com
# port 587
# from emilioj@udc.gal
# user emilio.padron@udc.es
